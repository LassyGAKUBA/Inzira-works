{
  "name": "inzira-works-backend",
  "version": "1.0.0",
  "description": "Backend API for Inzira Works — a platform connecting skilled women in Rwanda with customers.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:schema": "node src/db/runSchema.js",
    "db:seed": "node src/db/seeds/seed.js",
    "db:reset": "npm run db:schema && npm run db:seed"
  },
  "keywords": [
    "inzira-works",
    "express",
    "postgresql",
    "jwt"
  ],
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
